export JAVA_HOME=$(/usr/libexec/java_home -v 1.8)
export LANG=en_US.UTF-8
export LC_CTYPE=sv_SE.UTF-8
export LC_NUMERIC=sv_SE.UTF-8
export LC_TIME=sv_SE.UTF-8
export LC_COLLATE=sv_SE.UTF-8
export LC_MONETARY=sv_SE.UTF-8
export LC_MESSAGES=en_US.UTF-8
export LC_PAPER=sv_SE.UTF-8
export LC_NAME=sv_SE.UTF-8
export LC_ADDRESS=sv_SE.UTF-8
export LC_TELEPHONE=sv_SE.UTF-8
export LC_MEASUREMENT=sv_SE.UTF-8
export LC_IDENTIFICATION=sv_SE.UTF-8
export LC_ALL=en_US.UTF-8
export PATH=$HOME/.jenv/bin:/usr/local/bin:/usr/local/opt/ruby/bin:/usr/local/opt/gnu-sed/libexec/gnubin:/usr/local/opt/coreutils/libexec/gnubin:/usr/local/opt/findutils/libexec/gnubin:$HOME/go/bin:$PATH
export EDITOR=vim
