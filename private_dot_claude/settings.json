      "Bash(linear issue view *)",
      "Bash(linear issue view)",
      "Bash(linear i list *)",
      "Bash(linear i list)",
      "Bash(linear i v *)",
      "Bash(linear i v)",
      "Bash(but status)",
      "Bash(but status *)",
      "Bash(but -C * status)",
      "Bash(but -C * status *)",
      "Bash(but diff)",
      "Bash(but diff *)",
      "Bash(but -C * diff)",
      "Bash(but -C * diff *)",
      "Bash(but show *)",
      "Bash(but -C * show *)",
      "Bash(but branch list)",
      "Bash(but branch list *)",
      "Bash(but -C * branch list)",
      "Bash(but -C * branch list *)",
      "Bash(but pull)",
      "Bash(but pull *)",
      "Bash(but -C * pull)",
      "Bash(but -C * pull *)",
      "Bash(but oplog)",
      "Bash(but oplog *)",
      "Bash(but -C * oplog)",
      "Bash(but -C * oplog *)",
      "Bash(but config *)",
      "Bash(but -C * config *)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git -C * status *)",
      "Bash(git -C * status)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git -C * diff *)",
      "Bash(git -C * diff)",
      "Bash(git log *)",
      "Bash(git -C * log *)",
      "Bash(git show *)",
      "Bash(git -C * show *)",
      "Bash(git branch *)",
      "Bash(git branch)",
      "Bash(git -C * branch *)",
      "Bash(git -C * branch)",
      "Bash(git remote *)",
      "Bash(git -C * remote *)",
      "Bash(git tag *)",
      "Bash(git tag)",
      "Bash(git -C * tag *)",
      "Bash(git -C * tag)",
      "Bash(git stash list *)",
      "Bash(git stash list)",
      "Bash(git blame *)",
      "Bash(git -C * blame *)",
      "Bash(git shortlog *)",
      "Bash(git -C * shortlog *)",
      "Bash(git rev-parse *)",
      "Bash(git -C * rev-parse *)",
      "Bash(git ls-files *)",
      "Bash(git -C * ls-files *)",
      "Bash(git config --get *)",
      "Bash(git config --list *)",
      "Bash(git config --list)",
      "Bash(tree:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(git -C /Users/argoyle/.local/share/chezmoi status)",
      "Bash(git -C /Users/argoyle/.local/share/chezmoi diff --name-only)",
      "Bash(time zsh:*)",
      "Bash(find:*)",
      "Bash(bash:*)",
      "Bash(git -C /Users/argoyle/.local/share/chezmoi status --short)",
      "Bash(brew info:*)",
      "WebSearch",
      "Bash(brew list:*)",
      "WebFetch(domain:www.chezmoi.io)",
      "Bash(pass-cli item list:*)",
      "Bash(pass-cli item view:*)",
      "Bash(/usr/local/bin/lpass show:*)",
      "Bash(pass item get:*)",
      "Bash(pass item list:*)",
      "Bash(pass-cli vault list:*)",
      "Bash(chezmoi diff:*)",
      "Bash(lpass show:*)",
      "Bash(grep:*)",
      "Bash(lpass ls:*)",
      "Bash(chezmoi cat:*)",
      "WebFetch(domain:protonpass.github.io)",
      "Bash(but --help:*)",
      "Bash(but commit:*)",
      "Bash(but branch:*)",
      "WebFetch(domain:docs.gitbutler.com)",
      "WebFetch(domain:blog.gitbutler.com)",
      "WebFetch(domain:gist.github.com)",
