function 1plogin() {
  eval $(op signin volvo_cars_ccdp)
}

prepend_path() {
    for arg in "$@"; do
        if [[ ":${PATH}:" != *":${arg}:"* ]]; then
            export PATH="${arg}${PATH:+":$PATH"}"
        fi
    done
}

append_path() {
    for arg in "$@"; do
        if [[ ":${PATH}:" != *":${arg}:"* ]]; then
            export PATH="${PATH:+"$PATH:"}${arg}"
        fi
    done
}

function ecr  {
    eval $(aws ecr get-login --no-include-email)
}

function reload {
    exec zsh -l
}
